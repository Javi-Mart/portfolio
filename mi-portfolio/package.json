{
  "name": "mi-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NEXT_DISABLE_TURBOPACK=1 next build",
    "export:gh": "shx rm -rf .next out && next build && shx mkdir -p out/portfolio && shx mv out/_next out/models out/*.html out/*.txt out/*.svg out/*.ico out/portfolio 2>nul || true",
    "deploy": "pnpm build && shx touch out/.nojekyll && gh-pages -d out --dotfiles --no-history",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "next": "16.0.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.182.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "gh-pages": "^6.3.0",
    "serve": "^14.2.5",
    "shx": "^0.4.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
